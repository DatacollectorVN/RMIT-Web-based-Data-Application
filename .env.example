# PostgreSQL
# golang-migrate uses postgres:// scheme; SQLAlchemy converts it automatically to postgresql+asyncpg://.
# Entity primary keys are BIGINT (integer), not UUID.
DATABASE_URL=postgres://rmit:rmit@localhost:5432/rmit?sslmode=disable

POSTGRES_USER=rmit
POSTGRES_PASSWORD=rmit
POSTGRES_DB=rmit

# Python app service
PORT=8080

# OpenSearch
# For host-side scripts (make reindexproducts, make relevancecheck), use localhost.
# The docker-compose.yml overrides this to http://opensearch:9200 inside the container.
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PRODUCTS=products

# App
ENV=development

# Product photos (upload storage). Docker Compose mounts ./data/product-photos here:
# PRODUCT_PHOTOS_DIR=/var/lib/beauty-app/product-photos
# Local dev without Docker: leave unset to default to repo ./data/product-photos.
# PRODUCT_PHOTOS_DIR=

# UI / Vite dev proxy — backend API host
# Set in ui/.env (defaults to http://localhost:8080 if unset)
API_HOST=http://localhost:8080

# Optional (Phase 2 — token auth not used in Phase 1)
# JWT_SECRET=
# JWT_EXPIRY_HOURS=72
