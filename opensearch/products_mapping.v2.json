{
  "settings": {
    "index": {
      "knn": true,
      "analysis": {
        "filter": {
          "beauty_synonyms": {
            "type": "synonym",
            "synonyms": [
              "spf, sunscreen, sunblock",
              "moisturizer, moisturiser, cream",
              "cleanser, face wash, facial wash",
              "serum, treatment serum"
            ]
          }
        },
        "analyzer": {
          "beauty_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "beauty_synonyms"]
          }
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "product_id": { "type": "long" },
      "brand": {
        "type": "text",
        "analyzer": "beauty_analyzer",
        "fields": { "keyword": { "type": "keyword" } }
      },
      "name": {
        "type": "text",
        "analyzer": "beauty_analyzer",
        "fields": { "keyword": { "type": "keyword" } }
      },
      "description": { "type": "text", "analyzer": "beauty_analyzer" },
      "category": { "type": "keyword" },
      "price": { "type": "float" },
      "item_vector": {
        "type": "knn_vector",
        "dimension": 384,
        "method": {
          "name": "hnsw",
          "space_type": "cosinesimil",
          "engine": "nmslib"
        }
      },
      "updated_at": { "type": "date" }
    }
  }
}
